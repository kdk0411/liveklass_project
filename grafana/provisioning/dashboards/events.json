{
  "uid": "liveklass-events-v2",
  "title": "LiveKlass Event Dashboard (Updated)",
  "tags": ["liveklass"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
        "name": "event_type",
        "label": "이벤트 타입",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"lk_events\", tag: \"event_type\")",
        "refresh": 2,
        "type": "query",
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
        "name": "user_id",
        "label": "유저",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"lk_events\", tag: \"user_id\")",
        "refresh": 2,
        "type": "query",
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 20,
      "title": "Overview",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 21,
      "title": "전체 이벤트 수",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"}
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> filter(fn: (r) => r.event_type =~ /^${event_type}$/)\n  |> group()\n  |> count()"
        }
      ]
    },
    {
      "id": 22,
      "title": "활성 유저 수",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "green", "mode": "fixed"}
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> keep(columns: [\"user_id\"])\n  |> distinct(column: \"user_id\")\n  |> count()\n  |> group()\n  |> map(fn: (r) => ({_value: r._value, _field: \"전체 유저\"}))"
        }
      ]
    },
    {
      "id": 23,
      "title": "오류율",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.15}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "import \"array\"\n\ntotal = (from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> group()\n  |> count()\n  |> findRecord(fn: (key) => true, idx: 0))._value\n\nerror_rows = from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\" and r.status == \"fail\")\n  |> group()\n  |> count()\n  |> map(fn: (r) => ({_value: r._value}))\n\nerrors = (union(tables: [error_rows, array.from(rows: [{_value: 0}])])\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 1)\n  |> findRecord(fn: (key) => true, idx: 0))._value\n\nratio = float(v: errors) / float(v: if total == 0 then 1 else total)\n\narray.from(rows: [{_value: ratio}])"
        }
      ]
    },
    {
      "id": 24,
      "title": "구매 호출 수",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["sum"]},
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\" and r.event_type == \"purchase\")\n  |> group()\n  |> count()"
        }
      ]
    },
    {
      "id": 1,
      "title": "이벤트 타입별 발생 횟수",
      "type": "barchart",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "barRadius": 0.05,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> filter(fn: (r) => r.event_type =~ /^${event_type}$/)\n  |> group(columns: [\"event_type\"])\n  |> count()\n  |> group()\n  |> rename(columns: {_value: \"count\", event_type: \"_field\"})"
        }
      ]
    },
    {
      "id": 2,
      "title": "시간대별 이벤트 추이",
      "type": "timeseries",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> filter(fn: (r) => r.event_type =~ /^${event_type}$/)\n  |> group(columns: [\"event_type\"])\n  |> aggregateWindow(every: 1m, fn: count, createEmpty: true)\n  |> fill(value: 0)"
        }
      ]
    },
    {
      "id": 30,
      "title": "로그인 분석",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13}
    },
    {
      "id": 31,
      "title": "비밀번호 정책 위반 상세",
      "type": "barchart",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "barRadius": 0.05,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": false}
      },
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r.event_type == \"login_fail_password_policy\" and r._field == \"message\")\n  |> map(fn: (r) => ({r with violation: r._value}))\n  |> group(columns: [\"violation\"])\n  |> count()\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> rename(columns: {_value: \"count\", violation: \"_field\"})\n  |> keep(columns: [\"_field\", \"count\"])"
        }
      ]
    },
    {
      "id": 32,
      "title": "전환율 퍼널 (page_view → login → purchase)",
      "type": "barchart",
      "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "barRadius": 0.05,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "influxdb-liveklass"},
          "query": "from(bucket: \"lk_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"events\" and r._field == \"page\")\n  |> filter(fn: (r) => r.event_type == \"page_view\" or r.event_type == \"login_success\" or r.event_type == \"purchase\")\n  |> group(columns: [\"event_type\"])\n  |> count()\n  |> group()\n  |> rename(columns: {_value: \"count\", event_type: \"_field\"})"
        }
      ]
    }
  ]
}
